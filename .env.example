# UORA Platform Configuration
# Copy to .env and fill in your values

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:3000

# API Authentication
# Optional service-to-service API token. Browser users authenticate with email/password or Google OAuth.
UORA_API_TOKEN=

# Database
TIMESCALE_USER=uora
TIMESCALE_PASSWORD=replace-with-strong-timescale-password
TIMESCALE_DB=uora_metrics
TIMESCALEDB_URL=postgresql://uora:replace-with-strong-timescale-password@timescaledb:5432/uora_metrics

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_URL=redis://:replace-with-strong-redis-password@redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=uora
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_ACCESS_KEY=uora
MINIO_SECRET_KEY=replace-with-strong-minio-password
MINIO_BUCKET=uora-submissions

# Build Worker
BUILDKIT_ADDR=tcp://buildkitd:1234
REGISTRY_URL=localhost:5000
BUILDER_TIMEOUT=120

# Session
SESSION_SECRET=replace-with-strong-random-session-secret
SESSION_TTL_SECONDS=86400
COOKIE_SECURE=false

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Frontend API URL (used by Next.js to call the Python backend)
NEXT_PUBLIC_API_URL=http://localhost:8000
