# UORA Platform Configuration
# Copy to .env and fill in your values

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# API Authentication
UORA_API_TOKEN=  # Leave empty for dev mode (no auth)

# Database
TIMESCALEDB_URL=postgresql://uora:uora12345@timescaledb:5432/uora
TIMESCALEDB_PASSWORD=uora12345

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=uora_redis_2026

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uora-submissions

# Build Worker
BUILDKIT_ADDR=tcp://buildkitd:1234
REGISTRY_URL=localhost:5000
BUILDER_TIMEOUT=120

# Session
SESSION_SECRET=change-this-to-a-random-secret

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
