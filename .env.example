# UORA Platform Configuration
# Copy to .env and fill in your values

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# API Authentication
# Optional service-to-service API token. Browser users authenticate with email/password or Google OAuth.
UORA_API_TOKEN=

# Database
TIMESCALEDB_URL=postgresql://uora:uora12345@timescaledb:5432/uora_metrics
TIMESCALEDB_PASSWORD=uora12345

# Redis
REDIS_URL=redis://:uora12345@redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=uora12345

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=uora
MINIO_SECRET_KEY=uora12345
MINIO_BUCKET=uora-submissions

# Build Worker
BUILDKIT_ADDR=tcp://buildkitd:1234
REGISTRY_URL=localhost:5000
BUILDER_TIMEOUT=120

# Session
SESSION_SECRET=change-this-to-a-random-secret
SESSION_TTL_SECONDS=86400
COOKIE_SECURE=false

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Frontend API URL (used by Next.js to call the Python backend)
NEXT_PUBLIC_API_URL=http://localhost:8000
