# ──────────────────────────────────────────────────────────────────────────────
# UORA — production environment template.
# Copy to `.env` on the server and fill in every value. NEVER commit the real .env.
#
#   cp .env.production.template .env && nano .env
#
# Generate strong secrets with:  openssl rand -hex 32
# ──────────────────────────────────────────────────────────────────────────────

# ── Public URLs (what the browser hits) ─────────────────────────────────────
# For a bare-IP demo use http://<SERVER_IP>:8000 etc. For a domain use https://.
PUBLIC_API_URL=http://CHANGE_ME_SERVER_IP:8000
PUBLIC_REFERENCE_ENGINE_URL=http://CHANGE_ME_SERVER_IP:8081
NEXT_PUBLIC_API_URL=http://CHANGE_ME_SERVER_IP:8000
FRONTEND_URL=http://CHANGE_ME_SERVER_IP:3000
CORS_ORIGINS=http://CHANGE_ME_SERVER_IP:3000

# ── Sessions / auth ─────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_run_openssl_rand_hex_32
SESSION_TTL_SECONDS=86400
COOKIE_SECURE=false                 # set true once you have HTTPS
UORA_API_TOKEN=CHANGE_ME_service_token

# ── Google OAuth (optional — leave blank to disable the Google button) ──────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://CHANGE_ME_SERVER_IP:8000/auth/google/callback

# ── TimescaleDB / Postgres ──────────────────────────────────────────────────
TIMESCALE_USER=uora
TIMESCALE_PASSWORD=CHANGE_ME_strong_db_password
TIMESCALE_DB=uora_metrics
TIMESCALEDB_URL=postgresql://uora:CHANGE_ME_strong_db_password@timescaledb:5432/uora_metrics

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/0

# ── MinIO (object storage for submissions) ──────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=uora
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_storage_password
MINIO_ACCESS_KEY=uora
MINIO_SECRET_KEY=CHANGE_ME_strong_storage_password
MINIO_BUCKET=uora-submissions

# ── Sandbox builder ─────────────────────────────────────────────────────────
BUILDKIT_ADDR=tcp://buildkitd:1234
REGISTRY_URL=registry:5000
BUILDER_TIMEOUT=120
KUBERNETES_ENABLED=false            # true only on a K8s/gVisor cluster
GKE_SANDBOX_ENABLED=false
